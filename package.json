{
	"name": "@holston-platforms/holstonmeet",
	"type": "module",
	"scripts": {
		"build": "react-router build && node scripts/patch-server-build.mjs",
		"build:e2ee-worker": "./rust-mls-worker/build.sh",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"dev": "vite dev",
		"start": "wrangler dev ./build/index.js ${WRANGLER_ARGS:-}",
		"prebuild": "pnpm run clean",
		"clean": "del public/build && del build",
		"ci-test": "CI=true run-p typecheck test",
		"remove-sourcemaps": "del public/build/**/*.map",
		"deploy": "pnpm run check && pnpm run build && wrangler deploy",
		"typecheck": "tsc --noEmit --skipLibCheck",
		"typecheck:watch": "pnpm run typecheck -- --watch",
		"test": "vitest",
		"test:ci": "vitest --watch false",
		"test:e2e": "playwright test --headed",
		"check": "pnpm run lint && pnpm run typecheck && pnpm run test:ci",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply holstonmeet-db-development -c wrangler.development.jsonc --local",
		"db:migrate:development": "wrangler d1 migrations apply holstonmeet-db-development -c wrangler.development.jsonc --remote",
		"db:migrate:staging": "wrangler d1 migrations apply holstonmeet-db-staging -c wrangler.staging.jsonc --remote",
		"db:migrate:production": "wrangler d1 migrations apply holstonmeet-db-production -c wrangler.production.jsonc --remote",
		"db:studio:local": "LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
		"db:studio:development": "source .drizzle.env && DB_ID='YOUR_DEV_DB_ID' drizzle-kit studio",
		"db:studio:staging": "source .drizzle.env && DB_ID='YOUR_STAGING_DB_ID' drizzle-kit studio",
		"db:studio:production": "source .drizzle.env && DB_ID='YOUR_PROD_DB_ID' drizzle-kit studio",
		"seed": "tsx seed.ts"
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.42.1",
		"@heroicons/react": "^2.1.5",
		"@mediapipe/selfie_segmentation": "^0.1.1675465747",
		"@radix-ui/react-alert-dialog": "^1.1.1",
		"@radix-ui/react-checkbox": "^1.1.1",
		"@radix-ui/react-dialog": "^1.1.1",
		"@radix-ui/react-dropdown-menu": "^2.1.1",
		"@radix-ui/react-label": "^2.1.0",
		"@radix-ui/react-select": "^2.1.1",
		"@radix-ui/react-slot": "^1.1.0",
		"@radix-ui/react-switch": "^1.1.0",
		"@radix-ui/react-toast": "^1.2.1",
		"@radix-ui/react-tooltip": "^1.1.2",
		"@radix-ui/react-visually-hidden": "^1.1.0",
		"@react-router/cloudflare": "^7.17.0",
		"@react-router/fs-routes": "^7.17.0",
		"@tensorflow-models/body-segmentation": "^1.0.2",
		"@tensorflow/tfjs-backend-webgl": "^4.15.0",
		"@tensorflow/tfjs-core": "^4.15.0",
		"clsx": "^2.1.1",
		"cookie": "^0.6.0",
		"drizzle-orm": "^0.45.2",
		"good-grid": "^1.1.5",
		"nanoid": "^5.0.7",
		"partyserver": "^0.5.6",
		"partysocket": "^1.1.19",
		"partytracks": "^0.0.56",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-flip-toolkit": "^7.2.4",
		"react-router": "^7.17.0",
		"react-use": "^17.5.1",
		"rxjs": "^7.8.1",
		"tailwind-merge": "^3.6.0",
		"tiny-invariant": "^1.3.3",
		"webrtc-adapter": "^9.0.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@cloudflare/vitest-pool-workers": "^0.16.18",
		"@cloudflare/workers-types": "^4.20240806.0",
		"@peculiar/webcrypto": "^1.5.0",
		"@playwright/test": "^1.46.1",
		"@react-router/dev": "^7.17.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"better-sqlite3": "^11.3.0",
		"del-cli": "^5.1.0",
		"drizzle-kit": "^0.31.10",
		"git-format-staged": "^3.1.1",
		"glob": "^13.0.6",
		"msw": "^2.3.5",
		"npm-run-all": "^4.1.5",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^5.5.4",
		"vite": "^8.0.16",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "1.5.0",
		"wrangler": "^4.100.0"
	},
	"overrides": {
		"msw": {
			"typescript": "$typescript"
		}
	},
	"engines": {
		"node": ">=18",
		"packageManager": "pnpm@9.15.4"
	},
	"msw": {
		"workerDirectory": "public"
	}
}
